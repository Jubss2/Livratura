// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Livro{
  titulo String @id
  autor String
  dataPublicacao String
  paginas Int
  resumo String
  tags String[]
  estrelas Float
  grupos GrupoDeLeitura[]
  resenha Resenha[]
  usuariosLendo Usuario[]
  estantes estante[]
  catalogos livrosNoCatalogo[]
}
model livrosNoCatalogo {
  Catalogo Catalogo @relation( fields: [temaCat], references: [tema]) 
  temaCat String
  tituloLi String
  livros Livro @relation(fields: [tituloLi],references: [titulo])
  @@id([temaCat,tituloLi])
}
model GrupoDeLeitura{
  nome String @id
  dataCriacao String
  dataEncontro String
  tituloLivro String
  leituraConjunta Livro @relation(fields: [tituloLivro], references: [titulo])
  participantes Usuario[] @relation("participantesGDL")
}

model Usuario{
  id Int @id 
  senha String
  tituloLivro String?
  livroLendo Livro? @relation(fields: [tituloLivro],references: [titulo] )
  nome String @unique
  email String
  descricao String
  amigos UsuariosAmigo[] @relation("amigo")
  usuarioFonte UsuariosAmigo[] @relation("fonte")
  catalogosCriados Catalogo[] @relation("criacao")
  nomeGrupoDeLeitura String? 
  grupoDeLeitura GrupoDeLeitura? @relation("participantesGDL", fields: [nomeGrupoDeLeitura], references: [nome])
  metaDeLeitura MetaDeLeitura?
  nomeCom String?
  comunidade Comunidade? @relation(fields: [nomeCom],references: [nome])
  resenhas Resenha[]
  estantes estante[] 
  temaDesafio String? 
  desafio Catalogo? @relation(fields: [temaDesafio],references: [tema])
}
model UsuariosAmigo{
  idAmigo Int
  amigo Usuario @relation("amigo",fields: [idAmigo],references: [id])
  idUsu Int
  usuario Usuario @relation("fonte",fields: [idUsu],references: [id])
  @@id([idAmigo,idUsu])
}

model estante{
  usuario Usuario @relation( fields: [idUsu], references: [id])
  idUsu Int
  tituloLi String
  livros Livro @relation(fields: [tituloLi],references: [titulo])
  @@id([idUsu,tituloLi])
}

enum TipoCatalogo{
  COLECAO
  DESAFIO
}
model Catalogo{
  tema String @id
  curtidas Int
  tags String[]
  descricao String
  tipo TipoCatalogo
  visibilidade String?
  criterio String?
  livros livrosNoCatalogo[]
  idDono Int
  dono Usuario @relation("criacao",fields: [idDono], references: [id])
  medalhas Conquista[] 
  participantesDesafio Usuario[]
}

model MetaDeLeitura{
  nome String @id
  tipo String
  meta Int 
  progresso Int
  paginasLidas Int
  livrosLidos Int
  idUsuario Int @unique
  usuario Usuario @relation(fields: [idUsuario],references: [id])
  nomeConquista String
  conquista Conquista @relation(fields: [nomeConquista],references: [nome])
}

model Conquista{
  nome String @id 
  criterio String
  meta MetaDeLeitura[]
  temaCatalago String?
  desafio Catalogo? @relation(fields: [temaCatalago],references: [tema])
}

model Comunidade {
  nome String @id
  comentario String 
  data DateTime 
  curtidas Int
  participantes Usuario[] 
}
model Resenha{
  estrelas Float @id
  avaliacao String
  tituloLivro String
  livro Livro @relation(fields: [tituloLivro],references: [titulo])
  idUsu Int
  usuario Usuario @relation(fields: [idUsu],references: [id])
}
